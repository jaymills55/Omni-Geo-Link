rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /links/{linkId} {
      allow read: if true; // Public retrieval for redirection
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.ownerId);

      match /telemetry/{telemetryId} {
        allow read: if isOwner(get(/databases/$(database)/documents/links/$(linkId)).data.ownerId);
        allow create: if true; // Telemetry can be pushed during redirect
      }
    }

    match /clicks/{clickId} {
      allow read: if isSignedIn();
      allow write: if true;
    }
  }
}
